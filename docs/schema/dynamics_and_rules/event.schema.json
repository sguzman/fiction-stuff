{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Event Schema",
  "description": "Shocks to the system, historical or current.",
  "type": "object",
  "properties": {
    "id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "date": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "impacted_entities": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "required": [
    "id",
    "name"
  ]
}
