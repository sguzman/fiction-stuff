{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Epistemic State Schema",
  "description": "Models a character's interiority, beliefs, and memories.",
  "type": "object",
  "properties": {
    "id": { "type": "string" },
    "character_id": { "type": "string" },
    "beliefs": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "proposition": { "type": "string" },
          "is_true_in_world": { "type": "boolean" },
          "confidence": { "type": "number", "minimum": 0, "maximum": 100 }
        }
      }
    },
    "memories": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "event_id": { "type": "string" },
          "accuracy": { "type": "number", "minimum": 0, "maximum": 100 },
          "emotional_resonance": { "type": "string" }
        }
      }
    }
  },
  "required": ["id", "character_id"]
}
